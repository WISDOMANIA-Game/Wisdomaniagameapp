<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WISDOMANIA · Premium Wisdom</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,900&family=Karla:wght@400;500;700&family=Azeret+Mono:wght@500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
/* ===== RESET & VARIABLES ===== */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
:root {
--bg-base:#f4ede3; --bg-deep:#ebe2d5; --bg-card:rgba(255,250,242,0.92); --bg-input:#fff8ef;
--bg-input-border:#c9a84c; --text:#2a2117; --text-dim:#7a6c58; --gold:#b5880b; --gold-bright:#d4a017;
--gold-glow:rgba(181,136,11,0.25); --accent-red:#8b3a3a; --accent-teal:#2d6a4f; --accent-purple:#6b3a8b;
--border:rgba(181,136,11,0.22); --shadow-sm:0 2px 8px rgba(0,0,0,0.06); --shadow-md:0 8px 24px rgba(0,0,0,0.08);
--shadow-lg:0 16px 48px rgba(0,0,0,0.1); --radius-sm:14px; --radius-md:22px; --radius-lg:30px; --radius-full:999px;
}
html.dark {
--bg-base:#0e0d0a; --bg-deep:#18160f; --bg-card:rgba(28,25,18,0.88); --bg-input:#1a1710; --bg-input-border:#d4a017;
--text:#e8e0d0; --text-dim:#9a8e78; --gold:#d4a017; --gold-bright:#f0c850; --gold-glow:rgba(212,160,23,0.2);
--accent-red:#c75050; --accent-teal:#4eca8a; --accent-purple:#b070e0; --border:rgba(212,160,23,0.18);
--shadow-sm:0 2px 8px rgba(0,0,0,0.2); --shadow-md:0 8px 24px rgba(0,0,0,0.3); --shadow-lg:0 16px 48px rgba(0,0,0,0.4);
}
/* ===== TYPOGRAPHY ===== */
body{font-family:'Karla',sans-serif;font-size:16px;line-height:1.5;color:var(--text);background:var(--bg-base);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:16px;transition:background 0.4s ease;}
.font-display{font-family:'Fraunces',serif;}
.font-mono{font-family:'Azeret Mono',monospace;}
.app-container{max-width:500px;width:100%;display:flex;flex-direction:column;gap:16px;}
.card{background:var(--bg-card);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--radius-md);padding:20px;box-shadow:var(--shadow-md);opacity:0;transform:translateY(16px);animation:cardIn 0.5s ease forwards;}
.card:nth-child(1){animation-delay:0s;} .card:nth-child(2){animation-delay:0.08s;} .card:nth-child(3){animation-delay:0.16s;}
.card:nth-child(4){animation-delay:0.24s;} .card:nth-child(5){animation-delay:0.32s;} .card:nth-child(6){animation-delay:0.4s;}
.card:nth-child(7){animation-delay:0.48s;} .card:nth-child(8){animation-delay:0.56s;} .card:nth-child(9){animation-delay:0.64s;}
.card:nth-child(10){animation-delay:0.72s;}
.section-title{font-family:'Fraunces',serif;font-weight:700;font-size:1.25rem;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.section-title .icon-circle{width:34px;height:34px;border-radius:50%;background:var(--gold-glow);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.brand-header{text-align:center;padding:28px 20px 20px;}
.brand-header h1{font-family:'Fraunces',serif;font-weight:900;font-size:clamp(2.2rem,10vw,3.2rem);background:linear-gradient(135deg,var(--gold-bright),var(--gold),#c47a0a);-webkit-background-clip:text;background-clip:text;color:transparent;line-height:1.1;letter-spacing:-1px;animation:shimmer 3s ease-in-out infinite;background-size:200% 100%;}
.tagline{display:inline-block;margin-top:10px;padding:6px 20px;border-radius:var(--radius-full);border:1px solid var(--border);font-style:italic;font-size:0.9rem;color:var(--text-dim);background:var(--gold-glow);}
.daily-wisdom{margin-top:16px;padding:12px 16px;border-radius:var(--radius-sm);background:linear-gradient(135deg,var(--gold-glow),transparent);border-left:3px solid var(--gold);font-style:italic;font-size:0.9rem;color:var(--text-dim);min-height:60px;}
.daily-wisdom .wisdom-origin{display:block;margin-top:4px;font-size:0.78rem;color:var(--gold);font-style:normal;font-weight:700;}
.stats-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:14px;}
.stat-item{text-align:center;padding:10px 6px;border-radius:var(--radius-sm);background:var(--bg-deep);border:1px solid var(--border);}
.stat-value{font-family:'Azeret Mono',monospace;font-weight:700;font-size:1.8rem;color:var(--gold-bright);display:block;}
.stat-label{font-size:0.72rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-dim);margin-top:4px;}
.btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px 20px;border:none;border-radius:var(--radius-full);font-family:'Karla',sans-serif;font-weight:700;font-size:1rem;cursor:pointer;transition:transform 0.15s ease, box-shadow 0.15s ease;}
.btn:active{transform:translateY(2px);}
.btn-gold{background:linear-gradient(135deg,var(--gold-bright),var(--gold));color:#1a1400;box-shadow:0 4px 0 #8a6508, var(--shadow-sm);}
.btn-gold:active{box-shadow:0 1px 0 #8a6508;}
.btn-purple{background:linear-gradient(135deg,#a855f7,#7e22ce);color:white;box-shadow:0 4px 0 #5b21b6, var(--shadow-sm);}
.btn-purple:active{box-shadow:0 1px 0 #5b21b6;}
.btn-spin{background:linear-gradient(145deg,var(--gold-bright),#e8a800,var(--gold));color:#1a1400;font-family:'Fraunces',serif;font-size:1.3rem;font-weight:900;padding:18px;box-shadow:0 6px 0 #8a6508, var(--shadow-md);letter-spacing:1px;}
.btn-spin:active{box-shadow:0 2px 0 #8a6508;}
.result-box{margin-top:12px;padding:16px;border-radius:var(--radius-md);background:var(--bg-deep);border-left:4px solid var(--gold);font-size:0.95rem;line-height:1.6;color:var(--text);opacity:0;max-height:0;overflow:hidden;transition:opacity 0.4s ease,max-height 0.4s ease,padding 0.4s ease,margin 0.4s ease;}
.result-box.visible{opacity:1;max-height:400px;padding:16px;margin-top:12px;animation:resultPop 0.4s ease;}
.wheel-wrapper{position:relative;width:280px;height:280px;margin:10px auto 16px;}
.wheel-wrapper canvas{width:100%;height:100%;display:block;border-radius:50%;box-shadow:0 0 0 5px var(--gold),0 0 0 8px var(--border),var(--shadow-lg);}
.wheel-pointer{position:absolute;top:-12px;left:50%;transform:translateX(-50%);width:0;height:0;border-left:16px solid transparent;border-right:16px solid transparent;border-top:26px solid var(--gold-bright);filter:drop-shadow(0 4px 3px rgba(0,0,0,0.4));z-index:5;}
.wheel-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:42px;height:42px;border-radius:50%;background:linear-gradient(145deg,var(--gold-bright),var(--gold));border:3px solid var(--bg-base);z-index:4;box-shadow:var(--shadow-sm);}
.shop-item{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:var(--radius-sm);background:var(--bg-deep);border:1px solid var(--border);margin-bottom:10px;transition:transform 0.15s ease;}
.shop-item-info{display:flex;flex-direction:column;}
.shop-item-coins{font-family:'Azeret Mono',monospace;font-weight:700;color:var(--gold-bright);font-size:1rem;}
.shop-item-price{font-size:0.82rem;color:var(--text-dim);}
.btn-buy{padding:10px 20px;border-radius:var(--radius-full);border:none;background:linear-gradient(135deg,var(--gold-bright),var(--gold));color:#1a1400;font-weight:700;font-size:0.9rem;font-family:'Karla',sans-serif;cursor:pointer;}
.btn-buy:active{transform:scale(0.95);}
.premium-badge{display:inline-block;background:#a855f7;color:white;border-radius:var(--radius-full);padding:4px 12px;font-size:0.75rem;font-weight:700;margin-bottom:10px;}
.social-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.social-link{display:flex;align-items:center;gap:8px;padding:12px 18px;border-radius:var(--radius-full);background:var(--bg-deep);border:1px solid var(--border);color:var(--text);text-decoration:none;font-weight:500;font-size:0.9rem;transition:transform 0.15s ease,border-color 0.15s ease;}
.social-link:active{transform:scale(0.96);}
.social-link:hover{border-color:var(--gold);}
.social-link i{color:var(--gold);font-size:1.1rem;}
.footer-text{text-align:center;font-size:0.78rem;color:var(--text-dim);padding:10px 0 20px;}
.footer-text span{color:var(--gold);font-weight:700;}
@keyframes cardIn{to{opacity:1;transform:translateY(0);}}
@keyframes pulse{0%{transform:scale(1);}50%{transform:scale(1.25);}100%{transform:scale(1);}}
@keyframes shimmer{0%{background-position:200% 0;}100%{background-position:-200% 0;}}
@keyframes resultPop{0%{transform:scale(0.95);}60%{transform:scale(1.02);}100%{transform:scale(1);}}
</style>
</head>
<body>

<div class="app-container">

  <!-- Brand Header -->
  <div class="card brand-header">
    <h1 class="font-display">WISDOMANIA</h1>
    <div class="tagline">where faith meets culture & time becomes wisdom</div>
    <div class="daily-wisdom" id="dailyWisdom"></div>
    <div id="premiumBadge" class="premium-badge" style="display:none;">✨ PREMIUM MEMBER</div>
  </div>

  <!-- Stats Bar -->
  <div class="card stats-bar">
    <div class="stat-item">
      <span class="stat-value" id="coinDisplay">100</span>
      <span class="stat-label">🪙 Coins</span>
    </div>
    <div class="stat-item">
      <span class="stat-value" id="streakDisplay">0</span>
      <span class="stat-label">🔥 Streak</span>
    </div>
    <div class="stat-item">
      <span class="stat-value" id="pointsDisplay">0</span>
      <span class="stat-label">⭐ Points</span>
    </div>
  </div>

  <!-- Daily Alignment / Oracle -->
  <div class="card">
    <div class="section-title">
      <span class="icon-circle">🌅</span> Today's Energy
    </div>
    <div id="dayName" style="font-family:'Fraunces'; font-size:1.5rem; font-weight:700; margin-bottom:4px;">Orie 💧</div>
    <div id="dayQuestion" style="margin-bottom:14px; color:var(--text-dim); font-size:1rem;">Orie energy favors reflection and insight.</div>
    <div class="action-grid">
      <button class="action-btn" onclick="answer(0)">🔥 Start project</button>
      <button class="action-btn" onclick="answer(1)">💬 Share info</button>
      <button class="action-btn" onclick="answer(2)">🌊 Reset & reflect</button>
      <button class="action-btn" onclick="answer(3)">🌱 Harvest</button>
    </div>
    <div class="result-box" id="answerResult"></div>
  </div>

  <!-- Coin Shop -->
  <div class="card">
    <div class="section-title">
      <span class="icon-circle">🪙</span> Coin Shop
    </div>
    <div class="shop-item">
      <div class="shop-item-info">
        <span class="shop-item-coins">100 coins</span>
        <span class="shop-item-price">$1 · ₦500</span>
      </div>
      <button class="btn-buy" onclick="buyCoins(100)">Buy</button>
    </div>
    <div class="shop-item">
      <div class="shop-item-info">
        <span class="shop-item-coins">500 coins</span>
        <span class="shop-item-price">$5 · ₦2,500</span>
      </div>
      <button class="btn-buy" onclick="buyCoins(500)">Buy</button>
    </div>
    <div class="shop-item">
      <div class="shop-item-info">
        <span class="shop-item-coins">1,000 coins</span>
        <span class="shop-item-price">$10 · ₦5,000</span>
      </div>
      <button class="btn-buy" onclick="buyCoins(1000)">Buy</button>
    </div>
    <p class="shop-note">💳 Payments via Gumroad · 📱 OPay: 9012345678</p>
  </div>

  <!-- Premium Upgrade -->
  <div class="card">
    <div class="section-title">
      <span class="icon-circle">👑</span> Premium Upgrade
    </div>
    <p style="margin-bottom:14px;">Unlock 300+ exclusive oracle answers, remove ads, and earn bonus coins.</p>
    <button class="btn btn-purple" onclick="upgradeToPremium()"><i class="fa-solid fa-crown"></i> Upgrade for 500 coins</button>
  </div>

  <!-- Destiny Wheel -->
  <div class="card">
    <div class="section-title">
      <span class="icon-circle">🎡</span> Destiny Wheel
    </div>
    <div class="wheel-wrapper">
      <div class="wheel-pointer"></div>
      <canvas id="wheelCanvas" width="560" height="560"></canvas>
      <div class="wheel-center"></div>
    </div>
    <button class="btn btn-spin" onclick="spinWheel()">🎯 Spin (20 coins)</button>
  </div>

  <!-- Adsterra Ad -->
  <div id="adsterraSpace" style="width:100%; max-width:728px; margin:12px auto;"></div>
  <script type="text/javascript">
    var adsterra_id = "5679027";
    (function() {
        var a=document.createElement("script");
        a.async=true;
        a.src="https://adsterra.com/script.js?id="+adsterra_id;
        var s=document.getElements